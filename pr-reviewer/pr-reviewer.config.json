{
  "git": {
    "provider": "github",
    "repository": "JoilyFox/smr-template-e2e",
    "mainBranch": "main"
  },
  "jira": {
    "enabled": true,
    "baseUrl": "https://bohdanfstack.atlassian.net",
    "projectKey": "SCRUM",
    "ticketRegex": "SCRUM-\\d+"
  },
  "ai": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-5"
  },
  "rules": {
    "minScoreToSuggest": 20,
    "minScoreToPrompt": 50,
    "minScoreToAutoComment": 80
  }
}
